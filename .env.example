# RPC Solana — usa Helius gratis: https://helius.dev
SOLANA_RPC_HTTP=https://mainnet.helius-rpc.com/?api-key=TU_API_KEY
SOLANA_RPC_WS=wss://mainnet.helius-rpc.com/?api-key=TU_API_KEY

# RPC Ethereum — usa LlamaRPC gratis: https://llamarpc.com
ETH_RPC_HTTP=https://eth.llamarpc.com
ETHERSCAN_API_KEY=TU_ETHERSCAN_API_KEY

# Alchemy Webhooks — para detección ultra-rápida (< 100ms)
# Crea una API key gratis en: https://dashboard.alchemy.com
ALCHEMY_API_KEY=TU_ALCHEMY_API_KEY
WEBHOOK_PORT=8000
ETH_POLL_INTERVAL=3  # fallback si no hay webhooks

# Tu wallet Solana (dejar vacío para modo simulación)
WALLET_PUBKEY=
WALLET_PRIVKEY_B58=

# Tu wallet Ethereum para copy trading (dejar vacío si no haces live trading)
ETH_WALLET_ADDRESS=
ETH_WALLET_PRIVKEY=

# Wallets a copiar (separadas por coma) — soporta Solana y Ethereum
TARGET_WALLETS=wallet1,wallet2,0xETH_ADDRESS

# Configuración del bot
TRADE_AMOUNT_USD=10
MIN_PROFIT_USD=0.5
SLIPPAGE_BPS=50
