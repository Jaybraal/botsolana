# RPC Solana — usa Helius gratis: https://helius.dev
SOLANA_RPC_HTTP=https://mainnet.helius-rpc.com/?api-key=TU_API_KEY
SOLANA_RPC_WS=wss://mainnet.helius-rpc.com/?api-key=TU_API_KEY

# Tu wallet (dejar vacío para modo simulación)
WALLET_PUBKEY=
WALLET_PRIVKEY_B58=

# Wallets a copiar (separadas por coma)
TARGET_WALLETS=wallet1,wallet2

# Configuración del bot
TRADE_AMOUNT_USD=10
MIN_PROFIT_USD=0.5
SLIPPAGE_BPS=50
